# ---------------------------------------------------------------------------
# Copy to .env and adjust. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver). Local dev talks to the compose Postgres
# on host port 55432 (mapped to avoid a locally-installed Postgres on 5432).
DATABASE_URL=postgresql+asyncpg://bp:bp@localhost:55432/control_plane

# --- Auth -----------------------------------------------------------------
# Secret used to sign admin JWTs. Generate a strong one: `openssl rand -hex 32`
JWT_SECRET=change-me-please-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Single internal admin. For production set ADMIN_PASSWORD_HASH (a bcrypt hash,
# generate with: python -m app.auth.security "your-password").
# For local dev you may instead set ADMIN_PASSWORD (plaintext); the app will
# hash it at startup and log a warning. If both are set, the HASH wins.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=

# --- Telemetry / config delivery -----------------------------------------
# Public base URL where the collector is reachable by browsers. The config
# endpoint embeds "<PUBLIC_BASE_URL>/e" as the beaconUrl for the engine.
# Optional: leave UNSET in deployed envs to auto-derive from the request host
# (each environment then serves its own correct beacon/config URL).
PUBLIC_BASE_URL=http://localhost:8000

# Default Prebid.js bundle URL handed to the engine when a placement config
# does not override it. Matches the current engine release.
DEFAULT_PREBID_URL=https://cdn.jsdelivr.net/gh/shashwatsilverpush/bidding-player@v2.6.1/prebid/prebid.js

# Default sampling rate (0.0–1.0) applied to telemetry when a placement config
# does not override it.
DEFAULT_SAMPLE_RATE=1.0

# --- Consent policy -------------------------------------------------------
# What to do with a gdpr:true event that lacks the required consent signal.
#   anonymize -> store a minimal row (no page_url, no ip-derived country)
#   drop      -> discard entirely
CONSENT_MODE=anonymize

# --- Misc -----------------------------------------------------------------
# Comma-separated list of allowed admin CORS origins (dashboards). "*" ok for dev.
ADMIN_CORS_ORIGINS=*
LOG_LEVEL=INFO
